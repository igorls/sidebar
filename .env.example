# ---- Cerebras (OpenAI-compatible) ----
# universal-llm-client appends /v1 to the url, so DO NOT include /v1 here.
CEREBRAS_API_KEY=
CEREBRAS_BASE_URL=https://api.cerebras.ai
MODEL_ID=gemma-4-31b

# ---- Runtime modes ----
# AGENTS: mock  = replay the fixture's gold-label decisions (no API key needed)
#         live  = real Cerebras inference for router/summarizer/prototype
AGENTS=mock
# SOURCE: fixtures = replay test-transcripts.json as the transcript stream
#         asr      = Deepgram streaming (TODO)
SOURCE=fixtures
FIXTURE_SCENARIO=sprint-planning

# ---- Fact-check web search (Tavily) ----
# Free tier: 1,000 credits/mo (renews monthly), no credit card. Key looks like tvly-...
# Get one at https://app.tavily.com  (only used when AGENTS=live)
# FACTCHECK_SEARCH: tavily = ground verdicts on real web search (needs TAVILY_API_KEY)
#                   none   = model self-reports from its own knowledge (no search)
FACTCHECK_SEARCH=tavily
TAVILY_API_KEY=

# ---- Honest A/B GPU baseline (race Cerebras vs a GPU baseline, side by side) ----
# provider=ollama  -> native Ollama (local GPU, same model; thinking:false works here)
# provider=openai  -> any OpenAI-compatible GPU host (Together / Fireworks / vLLM)
# Example (local, same model as Cerebras):
#   BASELINE_PROVIDER=ollama
#   BASELINE_BASE_URL=http://localhost:11434
#   BASELINE_MODEL_ID=gemma4:31b-it-qat
BASELINE_PROVIDER=
BASELINE_BASE_URL=
BASELINE_API_KEY=
BASELINE_MODEL_ID=

# ---- ASR (live speech -> transcript) ----
# ElevenLabs Scribe v2 Realtime: browser streams mic audio directly to ElevenLabs
# using a 15-min single-use token minted by the server (GET /asr/token), so the
# key never reaches the client. If unset, the UI falls back to the free browser
# Web Speech API. Get a key at https://elevenlabs.io
ELEVENLABS_API_KEY=
# DEEPGRAM_API_KEY=   # alternative ASR backend (not wired)

# ---- Server ----
PORT=3001
# Every meeting writes prototypes, recap, transcript, summary, and DESIGN.md here.
# In Docker this path is mounted to ./exports on the host by docker-compose.yml.
EXPORTS_DIR=exports

# ---- Host passcode (lock the live experience) ----
# The single secret the HOST uses to connect to their own server. When set it (a)
# gates the WebSocket, ASR endpoints, and context uploads, and (b) grants the
# server-authoritative `host` role (so `?host` in the URL can no longer self-promote).
# GUESTS never use this — the host mints a UNIQUE invite code per guest from the in-app
# "Invite" button; each guest's link carries their own `?key=<code>`. Empty = open
# (fine for local dev: anyone can host). Takes effect on server start, so restart after
# changing it. MEETING_PASSWORD is still honoured as an alias for HOST_PASSCODE.
HOST_PASSCODE=
# MEETING_PASSWORD=   # legacy alias for HOST_PASSCODE

# ---- Tailscale (Docker sidecar) ----
# Only used by docker-compose.yml — runs the app as an isolated tailnet node instead of
# funneling from your host. Create an ephemeral + reusable auth key at
# https://login.tailscale.com/admin/settings/keys . The app is then served tailnet-only
# (Tailscale `serve`, not funnel) at https://<TS_HOSTNAME>.<your-tailnet>.ts.net
TS_AUTHKEY=
TS_HOSTNAME=sidebar
